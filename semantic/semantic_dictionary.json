{
  "business_context": "Data Mart de ventas para Target.",
  "allowed_tables": [
    "fact_ventas_promociones",
    "dim_cliente",
    "dim_producto",
    "dim_sede",
    "dim_tiempo"
  ],
  "metrics": {
    "total_ventas_por_producto":"ROUND(cantidad * precio_unitario, 2)",
    "mnpd_por_venta": "ROUND(ventas - (cantidad * precio_unitario * monto_descuento) - costo_envio, 2)",
    "impacto_descuento_porcentaje": "ROUND((SUM(cantidad * precio_unitario * monto_descuento) / SUM(ventas)) * 100, 2)",
    "ventas_por_categoria": "ROUND(SUM(ventas), 2)",
    "ventas_por_mes": "ROUND(SUM(ventas), 2)"
  },
  "tables": {
