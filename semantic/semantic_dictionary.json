        "cantidad": "Cantidad vendida.",
        "precio_unitario": "Precio unitario.",
        "costo_envio": "Precio del Envio.",
        "margen_base": "Porcentaje de ganancia",
        "ganancias": "Ganancia bruta por producto vendido.",
        "costo_total_producto": "Costo del producto a Target",
        "mnpd": "Margen Neto Post Descuento"
        
      }
    },
    "dim_cliente": {
      "grain": "Una fila representa un cliente.",
